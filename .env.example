# medi-vault environment configuration
# Copy to .env and fill in values

# PostgreSQL
POSTGRES_USER=medi-vault
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=medi-vault

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMADB_URL=http://chromadb:8000

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_NAME=llama3:8b

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change-me-generate-with-fernett

# Google OAuth (optional — for Google Fit sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# App settings
AUTO_DELETE_PDFS=false
MAX_UPLOAD_SIZE_MB=50
SYNC_INTERVAL_HOURS=6

# Backend
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
